#Directory aliases
alias cdd='cd ~/Downloads'
alias cdb='cd ~/bin'
alias cdh='cd ~/'
alias cdpython='cd ~/Programming/PythonCode'

#Command aliases
alias p='sudo pacman'
alias ka='killall'

#Internet
alias yt="youtube-dl --add-metadata -ic" # Download video link
alias yta="youtube-dl --add-metadata -xic" # Download only audio
alias YT="youtube-viewer"

